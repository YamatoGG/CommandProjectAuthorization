<Window x:Class="WpfApp3.Views.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список товаров" 
        Height="550" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        FontFamily="Segoe UI">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Заголовок -->
		<TextBlock Text="Каталог товаров" 
                   FontSize="26" FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,25"
                   Foreground="#2C3E50"
                   Grid.Row="0"/>

		<!-- Таблица товаров -->
		<DataGrid x:Name="dgProducts"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#BDC3C7"
                  BorderThickness="1"
                  RowHeight="45"
                  FontSize="14"
                  Margin="0,0,0,20"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8F9F9">

			<DataGrid.Columns>

				<DataGridTextColumn Header="ID" 
                                    Binding="{Binding Id}" 
                                    Width="80"
                                    HeaderStyle="{StaticResource HeaderStyleCenter}"
                                    ElementStyle="{StaticResource CellStyleCenter}"/>

				
				<DataGridTextColumn Header="Наименование товара" 
                                    Binding="{Binding Name}" 
                                    Width="*"
                                    HeaderStyle="{StaticResource HeaderStyleLeft}"
                                    ElementStyle="{StaticResource CellStyleLeft}"/>

				
				<DataGridTextColumn Header="Цена (руб.)" 
                                    Binding="{Binding Price, StringFormat=N2}" 
                                    Width="150"
                                    HeaderStyle="{StaticResource HeaderStyleCenter}"
                                    ElementStyle="{StaticResource CellStyleRight}"/>
			</DataGrid.Columns>
		</DataGrid>

		<!-- Нижняя панель с кнопками -->
		<StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">

			<!-- Информация о количестве товаров -->
			<TextBlock x:Name="txtTotal" 
                       Text="Всего товаров: 0" 
                       FontSize="14"
                       Foreground="#2C3E50"
                       FontWeight="SemiBold"
                       Margin="0,0,20,0"
                       VerticalAlignment="Center"/>

			<!-- Кнопка обновления -->
			<Button Content="Обновить список" 
                    x:Name="btnRefresh"
                    Click="btnRefresh_Click"
                    Width="140" Height="40"
                    Background="#3498DB"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand">
				<Button.Resources>
					<Style TargetType="Border">
						<Setter Property="CornerRadius" Value="5"/>
					</Style>
				</Button.Resources>
			</Button>
		</StackPanel>
	</Grid>
</Window>